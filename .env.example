POSTGRES_DB=ml_portfolio
POSTGRES_USER=
POSTGRES_PASSWORD=
JWT_SECRET=

# --- MinIO object store (local artifact delivery) ---
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Artifact source dirs (machine-specific, used only when seeding the bucket)
NLP_ARTIFACT_SOURCE_DIR=
CV_ARTIFACT_SOURCE_DIR=

ARTIFACT_BUCKET=ml-artifacts
ARTIFACT_VERSION=1.0.0

# --- Cloudflare R2 (remote artifact store for Fly.io deployment) ---
# Leave blank for local MinIO workflow; fill in for R2 seeding / Fly.io deployment
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- mc alias overrides (used by minio-seed to target R2 instead of local MinIO) ---
# Defaults (local MinIO) are baked in; only set these when seeding R2:
#   MC_ALIAS_NAME=r2
#   MC_ALIAS_URL=<R2_ENDPOINT>
#   MC_ACCESS_KEY=<R2_ACCESS_KEY_ID>
#   MC_SECRET_KEY=<R2_SECRET_ACCESS_KEY>
MC_ALIAS_NAME=
MC_ALIAS_URL=
MC_ACCESS_KEY=
MC_SECRET_KEY=
